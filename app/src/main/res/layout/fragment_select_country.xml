                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Laos"
                    android:textSize="18sp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/inter"
                    android:layout_marginStart="30dp" />

